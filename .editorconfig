# EditorConfig — keeps formatting consistent across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{rs,toml}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # Markdown uses trailing spaces for line breaks

[*.{ps1,bat,cmd}]
end_of_line = crlf
