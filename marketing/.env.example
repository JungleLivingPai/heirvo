# Heirvo marketing site — environment variables.
#
# DO NOT commit a real .env file. Set live values in the Vercel dashboard:
#   https://vercel.com/junglelivingpais-projects/heirvo/settings/environment-variables
#
# Each variable below must be set in BOTH the Vercel dashboard (for production)
# AND a local `.env` file (for `npm run dev`). The local .env is git-ignored.

# Formspree form ID — handles mail-in order form submissions.
# Get yours at: https://formspree.io
VITE_FORMSPREE_ID=your_formspree_id

# Stripe Payment Link URL for the $19.99 mail-in intake fee.
# CRITICAL: must be the LIVE Payment Link (https://buy.stripe.com/<id>),
# NOT a test-mode link (https://buy.stripe.com/test_<id>). A test link
# will route real customers' charges to test mode and they never settle.
VITE_STRIPE_INTAKE_URL=https://buy.stripe.com/replace-me

# Lemon Squeezy checkout URL for Heirvo Pro ($39 one-time).
# Get yours from your LS product page -> Share -> Checkout URL.
# Example: https://heirvo.lemonsqueezy.com/buy/<product-uuid>
VITE_LS_CHECKOUT_URL=https://heirvo.lemonsqueezy.com/buy/replace-me

# Direct link to the latest installer (GitHub Releases, S3, etc.)
VITE_DOWNLOAD_URL=https://github.com/JungleLivingPai/heirvo/releases/latest/download/Heirvo_1.0.0_x64-setup.exe
