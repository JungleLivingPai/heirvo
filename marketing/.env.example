# Copy this to .env.local for local dev, or set in Vercel dashboard for production.

# Direct link to the latest installer (GitHub Releases, S3, etc.)
VITE_DOWNLOAD_URL=https://github.com/your-username/heirvo/releases/latest/download/Heirvo_0.1.0_setup.exe

# Lemon Squeezy checkout URL for the Pro plan
VITE_LS_CHECKOUT_URL=https://heirvo.lemonsqueezy.com/checkout/buy/replace-me

# Formspree form ID for the mail-in order form on /recover
VITE_FORMSPREE_ID=your_formspree_id

# Stripe Payment Link for the $19.99 non-refundable intake fee (test vs live)
VITE_STRIPE_INTAKE_URL=https://buy.stripe.com/replace-me
