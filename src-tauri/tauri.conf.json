{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Heirvo",
  "version": "0.1.0",
  "identifier": "com.heirvo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Heirvo",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "Copyright (c) 2026 Heirvo",
    "shortDescription": "Recover damaged DVDs, photo CDs, and audio CDs",
    "longDescription": "Heirvo rescues data from damaged optical media — DVDs, photo CDs, document CDs, audio CDs. Multi-pass sector recovery, resumable sessions, AI restoration. Built for non-technical users.",
    "resources": [
      "resources/ffmpeg/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "sidebarImage": "installer-sidebar.bmp",
        "headerImage": "installer-sidebar.bmp"
      }
    },
    "createUpdaterArtifacts": false
  }
}
